# ── Sentinel EMS ──────────────────────────────────────────────────────────────
SENTINEL_EMS_URL=https://p0n8ol.trial.sentinelcloud.com
SENTINEL_EMS_USERNAME=admin
SENTINEL_EMS_PASSWORD=your_password_here

# ── Enforcement Policy ────────────────────────────────────────────────────────
# open  = allow through if EMS unreachable and cache expired
# closed = deny if EMS unreachable and cache expired
ENFORCEMENT_FAIL_MODE=open

# ── Security ──────────────────────────────────────────────────────────────────
# Any secret string — your test app must send this in x-enforcement-key header
ENFORCEMENT_API_KEY=change-me-to-any-secret

# ── Cache Tuning (optional) ───────────────────────────────────────────────────
CACHE_TTL_MS=120000        # 2 min — serve fresh from cache
CACHE_STALE_MAX_MS=300000  # 5 min — serve stale while refreshing in background

# ── Redis (optional) ─────────────────────────────────────────────────────────
# Leave blank to use in-memory cache
# Set to your Railway Redis URL for multi-instance deployments
# REDIS_URL=redis://default:password@host:6379
